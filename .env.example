# Docker image tag to run.
GADS_IMAGE_TAG=latest

# Hub.
GADS_HUB_HOST=127.0.0.1
GADS_HUB_PORT=10000
GADS_AUTH=false

# MongoDB.
GADS_MONGO_PORT=27017

# Provider.
GADS_PROVIDER_NICKNAME=DockerProvider
GADS_PROVIDER_HOST=127.0.0.1
GADS_PROVIDER_PORT=11000
GADS_PROVIDER_LOG_LEVEL=info

# Optional one-device seed. You can also add devices later in the GADS UI.
GADS_SEED_DEVICE=false
GADS_DEVICE_UDID=
GADS_DEVICE_NAME=Android Device
GADS_DEVICE_OS_VERSION=13
GADS_DEVICE_SCREEN_WIDTH=720
GADS_DEVICE_SCREEN_HEIGHT=1650
GADS_DEVICE_STREAM_TYPE=mjpeg
